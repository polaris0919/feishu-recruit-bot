# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.ruff_cache/
*.egg-info/
.eggs/
dist/
build/
.venv/
**/.venv/

# Accidental / editor noise
**/sfully*
.idea/
.vscode/
*.swp
*~
.DS_Store

# Local runtime config / state
config/*.json
state/*.json
!config/*.example.json

# Runtime inbound CV attachments
data/media/inbound/
data/media/

# Local recruiting artifacts / historical candidate data
data/followup_archive/
data/followup_pending/
data/standard_answer/
data/deleted_archive/

# v3.5.6: inbox.cmd_scan 落盘的候选人邮件附件（简历/笔试代码/作品集等敏感内容）
data/candidate_answer/

# v3.5.8: 候选人统一资料目录（cv/exam_answer/email），含敏感简历 / 笔试代码
data/candidates/

# v3.5.12 cron heartbeat 文件（运行时心跳，不该入库）
data/.cron_heartbeat

# v3.5.10 systemd 旧 timer/service 备份（迁移到 recruit-cron-runner.timer 时存档；本地审计用，不入库）
data/systemd_backup_*/

# 编辑器 / 升级备份后缀（如 SKILL.md.bak.v353）
*.bak.*
*.bak

# data/onoffer_data/ 是入职邮件自动附件（致邃实习协议模板 + 入职信息登记表），非 PII，必须入库 → 显式 unignore 防止误伤
!data/onoffer_data/
!data/onoffer_data/**

# A4.2 (v3.8.7): pytest-cov 跑出来的二进制 sqlite, 不可读 diff, 永不入库
.coverage
coverage.xml
htmlcov/
